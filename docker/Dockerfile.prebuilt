# Use this when the JAR is already built locally (target/*.jar exists).
# Build from repo root:
#   docker build -f docker/Dockerfile.prebuilt --build-arg MODULE_DIR=demoEurekaServer .

FROM eclipse-temurin:17-jre-jammy
ARG MODULE_DIR
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY ${MODULE_DIR}/target/*.jar app.jar
ENTRYPOINT ["java", "-jar", "app.jar"]
