    {
      "name": "MSLaboratoir — Laboratoires",
      "description": "Laboratory management. Publishes analysis requests and completions via RabbitMQ.",
      "item": [
        {
          "name": "Hello Laboratoire",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{laboratoir_url}}/laboratoires/hello",
              "host": ["{{laboratoir_url}}"],
              "path": ["laboratoires", "hello"]
            },
            "description": "Health-check endpoint."
          },
          "response": []
        },
        {
          "name": "Welcome Laboratoire",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{laboratoir_url}}/laboratoires/welcome",
              "host": ["{{laboratoir_url}}"],
              "path": ["laboratoires", "welcome"]
            },
            "description": "Welcome endpoint."
          },
          "response": []
        },
        {
          "name": "Get All Laboratoires",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{laboratoir_url}}/laboratoires",
              "host": ["{{laboratoir_url}}"],
              "path": ["laboratoires"]
            },
            "description": "Returns all laboratoires in the database."
          },
          "response": []
        },
        {
          "name": "Publish Analysis Request (RabbitMQ)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 1,\n  \"medcinId\": 2,\n  \"laboratoireId\": 1,\n  \"type\": \"Bilan sanguin\",\n  \"status\": \"PENDING\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{laboratoir_url}}/laboratoires/analysis-requests",
              "host": ["{{laboratoir_url}}"],
              "path": ["laboratoires", "analysis-requests"]
            },
            "description": "Publishes an analysis request message to RabbitMQ.\n\ntype examples: Bilan sanguin, Radiographie, IRM, Scanner, Echographie, Analyse urinaire.\nstatus: PENDING, IN_PROGRESS, COMPLETED, CANCELLED."
          },
          "response": []
        },
        {
          "name": "Publish Analysis Completed (RabbitMQ)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"analysisId\": 1,\n  \"ordonnanceId\": 1,\n  \"patientId\": 1,\n  \"medcinId\": 2,\n  \"result\": \"Résultats normaux. Aucune anomalie détectée.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{laboratoir_url}}/laboratoires/analysis-completed",
              "host": ["{{laboratoir_url}}"],
              "path": ["laboratoires", "analysis-completed"]
            },
            "description": "Publishes an analysis-completed message to RabbitMQ once laboratory results are ready."
          },
          "response": []
        }
      ]
    },
