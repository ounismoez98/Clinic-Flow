{
  "info": {
    "_postman_id": "clinic-flow-collection-v1",
    "name": "Clinic-Flow Microservices",
    "description": "Full API collection for Clinic-Flow microservices: MSPatientMedcin (8082), MSUser (8083), MSLaboratoir (8081), MSOrdonnance (8081), MSRendezVous (8081). All services are also accessible via the API Gateway on port 8085.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gateway", "value": "http://localhost:8085", "type": "string" },
    { "key": "patient_medcin_url", "value": "http://localhost:8082", "type": "string" },
    { "key": "user_url", "value": "http://localhost:8083", "type": "string" },
    { "key": "laboratoir_url", "value": "http://localhost:8081", "type": "string" },
    { "key": "ordonnance_url", "value": "http://localhost:8081", "type": "string" },
    { "key": "rendezvous_url", "value": "http://localhost:8081", "type": "string" }
  ],
  "item": [
    {
      "name": "MSPatientMedcin — Patients",
      "description": "CRUD operations for patients. POST/PUT also publish a RabbitMQ message to MSUser via the clinic.patient.exchange.",
      "item": [
        {
          "name": "Get All Patients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{patient_medcin_url}}/patients",
              "host": ["{{patient_medcin_url}}"],
              "path": ["patients"]
            },
            "description": "Returns a list of all patients."
          },
          "response": []
        },
        {
          "name": "Get Patient By ID (with Linked User Account)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{patient_medcin_url}}/patients/1/with-linked-account",
              "host": ["{{patient_medcin_url}}"],
              "path": ["patients", "1", "with-linked-account"]
            },
            "description": "Returns the patient along with their linked MSUser account (fetched via Feign). Replace '1' with the target patient ID."
          },
          "response": []
        },
        {
          "name": "Create Patient",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Ben Ali\",\n  \"prenom\": \"Yassine\",\n  \"email\": \"yassine.benali@clinic.tn\",\n  \"userId\": 1,\n  \"favoriteMedecinIds\": []\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{patient_medcin_url}}/patients",
              "host": ["{{patient_medcin_url}}"],
              "path": ["patients"]
            },
            "description": "Creates a new patient. Publishes a PatientUserLinkedMessage to RabbitMQ (queue: patient.user.linked.queue) so MSUser can link the account. Returns HTTP 201."
          },
          "response": []
        },
        {
          "name": "Update Patient",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Ben Ali\",\n  \"prenom\": \"Yassine Updated\",\n  \"email\": \"yassine.updated@clinic.tn\",\n  \"userId\": 1,\n  \"favoriteMedecinIds\": [2, 3]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{patient_medcin_url}}/patients/1",
              "host": ["{{patient_medcin_url}}"],
              "path": ["patients", "1"]
            },
            "description": "Updates an existing patient. Replace '1' with the target patient ID."
          },
          "response": []
        },
        {
          "name": "Delete Patient",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{patient_medcin_url}}/patients/1",
              "host": ["{{patient_medcin_url}}"],
              "path": ["patients", "1"]
            },
            "description": "Deletes a patient by ID. Returns HTTP 204. Replace '1' with the target patient ID."
          },
          "response": []
        },
        {
          "name": "Get Favorite Medecins of Patient",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{patient_medcin_url}}/patients/1/favorite-medecins",
              "host": ["{{patient_medcin_url}}"],
              "path": ["patients", "1", "favorite-medecins"]
            },
            "description": "Returns the list of favorite medecins for the given patient ID."
          },
          "response": []
        },
        {
          "name": "Add Favorite Medecin to Patient",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{patient_medcin_url}}/patients/1/favorite-medecins/2",
              "host": ["{{patient_medcin_url}}"],
              "path": ["patients", "1", "favorite-medecins", "2"]
            },
            "description": "Adds medecin with ID '2' to the favorite list of patient with ID '1'. No request body needed."
          },
          "response": []
        }
      ]
    },
