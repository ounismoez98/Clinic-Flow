# Copy to .env and adjust if needed.

PORT=5000

# Keycloak (same realm as Clinic-Flow)
KEYCLOAK_BASE_URL=http://localhost:8180
KEYCLOAK_REALM=clinic-flow

# The token issuer must match what Keycloak puts in the token's "iss" claim.
KEYCLOAK_ISSUER=http://localhost:8180/realms/clinic-flow

# Keycloak admin (master realm) — used for the admin API (manage users/roles)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Allow the Angular dev server to call this API
CORS_ORIGIN=http://localhost:4200

# Shared secret for trusted backend-to-backend calls (MSPatientMedcin -> this service)
INTERNAL_API_KEY=clinicflow-internal-secret

# Eureka (so the Spring gateway can discover this service)
EUREKA_HOST=localhost
EUREKA_PORT=8761
# Hostname/IP other services use to reach THIS node app.
# Local dev: localhost | inside Docker: host.docker.internal or the container host
SERVICE_HOSTNAME=localhost
# The name the gateway routes to: lb://IDENTITY-SERVICE
SERVICE_NAME=IDENTITY-SERVICE
